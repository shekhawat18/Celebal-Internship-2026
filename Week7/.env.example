# Copy this file to ".env" and fill in the values you need.
# Only required if you set LLM_BACKEND=anthropic or LLM_BACKEND=openai in config.py

ANTHROPIC_API_KEY=your_anthropic_key_here
OPENAI_API_KEY=your_openai_key_here

# Which generation backend to use: anthropic | openai | local
LLM_BACKEND=local
